<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Spinner
            android:id="@+id/spinnerProfiles"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2" />

        <Button android:id="@+id/btnSave" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="@string/action_save" />
        <Button android:id="@+id/btnDelete" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="@string/action_delete" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/editHost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:hint="@string/hint_host"
            android:textSize="18sp"
            android:inputType="textUri"
            android:imeOptions="actionNext"
            android:singleLine="true" />

        <EditText
            android:id="@+id/editPort"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:hint="@string/hint_port"
            android:text="22"
            android:textSize="18sp"
            android:inputType="number"
            android:singleLine="true"
            android:imeOptions="actionNext" />

        <EditText
            android:id="@+id/editUser"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:layout_marginStart="12dp"
            android:hint="@string/hint_user"
            android:textSize="18sp"
            android:inputType="text"
            android:singleLine="true"
            android:imeOptions="actionNext"
            android:autofillHints="username" />

        <EditText
            android:id="@+id/editPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:layout_marginStart="12dp"
            android:hint="@string/hint_password"
            android:textSize="18sp"
            android:inputType="textPassword"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:autofillHints="password" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button android:id="@+id/btnImportKey" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="16sp" android:text="@string/action_import_key" />

        <TextView
            android:id="@+id/txtIdentity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textSize="16sp"
            android:text="@string/identity_none"
            android:singleLine="true"
            android:ellipsize="middle" />

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:layout_marginStart="16dp"
            android:padding="12dp"
            android:background="@color/status_bar"
            android:textColor="@color/status_text"
            android:textSize="16sp"
            android:text="@string/status_disconnected"
            android:singleLine="true"
            android:ellipsize="end" />

        <Button android:id="@+id/btnConnect" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:textSize="16sp" android:text="@string/action_connect" />
    </LinearLayout>

    <include layout="@layout/key_toolbar" />

    <ScrollView
        android:id="@+id/scrollOutput"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:background="@color/terminal_bg"
        android:padding="10dp"
        android:scrollbars="vertical"
        android:fillViewport="true">

        <EditText
            android:id="@+id/txtOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:fontFamily="monospace"
            android:textColor="@color/terminal_fg"
            android:textSize="15sp"
            android:gravity="top"
            android:inputType="textMultiLine|textNoSuggestions|textVisiblePassword"
            android:imeOptions="actionNone|flagNoExtractUi"
            android:enabled="false"
            android:text="@string/welcome_banner" />
    </ScrollView>
</LinearLayout>
